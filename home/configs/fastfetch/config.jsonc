{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "nixos",
        "type": "builtin",
        "padding": {
            "top": 3,
            "left": 3,
            "right": 5,
        },
        "color": {
            "1": "#f2be6e",
            "2": "#dcc3a1" 
        }
    },
    "modules": [
        "break",
        {
            "type": "custom",
            "format": "\u001b[90m┌───────────────────────Hardware──────────────────────────┐"
        },
        {
            "type": "host",
            "key": "󰌢  PC",
            "keyColor": "#f2be6e"
        },
        {
            "type": "cpu",
            "key": "│ ├󰻠 ",
            "keyColor": "#f2be6e"
        },
        {
            "type": "gpu",
            "key": "│ ├󰍹 ",
            "keyColor": "#f2be6e"
        },
        {
            "type": "memory",
            "key": "│ ├󰑭 ",
            "keyColor": "#f2be6e"
        },
        {
            "type": "disk",
            "key": "└ └󰋊 ",
            "keyColor": "#f2be6e"
        },
        {
            "type": "custom",
            "format": "\u001b[90m└─────────────────────────────────────────────────────────┘"
        },
        "break",
        {
            "type": "custom",
            "format": "\u001b[90m┌───────────────────────Software──────────────────────────┐"
        },
        {
            "type": "os",
            "key": "  OS",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "kernel",
            "key": "│ ├󰌽 ",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "packages",
            "key": "│ ├󰏗 ",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "shell",
            "key": "└ └󰞷 ",
            "keyColor": "#dcc3a1"
        },
        "break",
        {
            "type": "lm",
            "key": "│ ├󰍁 ",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "wm",
            "key": "│ ├󱂬 ",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "terminal",
            "key": "└ └󰆍 ",
            "keyColor": "#dcc3a1"
        },
        {
            "type": "custom",
            "format": "\u001b[90m└─────────────────────────────────────────────────────────┘"
        },
        "break",
        {
            "type": "custom",
            "format": "\u001b[90m┌────────────────────────Stats────────────────────────────┐"
        },
        {
            "type": "command",
            "key": "  ›  OS Age  ",
            "keyColor": "#b6cea3",
            "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days"
        },
        {
            "type": "uptime",
            "key": "  ›  Uptime  ",
            "keyColor": "#b6cea3"
        },
        {
            "type": "custom",
            "format": "\u001b[90m└─────────────────────────────────────────────────────────┘"
        },
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        }
    ]
}
