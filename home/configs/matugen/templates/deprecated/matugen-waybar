
/* Matugen mapping for HyDE Waybar */

@define-color main-bg {{colors.on_secondary_fixed.default.hex}};
@define-color main-fg {{colors.on_surface.default.hex}};

/* Bar Background */
@define-color bar-bg alpha({{colors.surface.default.hex}}, 0);

/* Active States (Workspaces/Taskbar) */
@define-color wb-act-bg {{colors.primary.default.hex}};
@define-color wb-act-fg {{colors.on_primary.default.hex}};
@define-color wb-act-color {{colors.on_primary.default.hex}};

/* Hover States */
@define-color wb-hvr-bg {{colors.secondary.default.hex}};
@define-color wb-hvr-fg {{colors.on_secondary.default.hex}};
@define-color wb-hvr-color {{colors.on_secondary.default.hex}};

/* Generic Color (often used for icons) */
@define-color wb-color {{colors.primary.default.hex}};
