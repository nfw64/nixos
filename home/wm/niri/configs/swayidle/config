# Screen dimming
timeout 150 'brightnessctl -s set 10' resume 'brightnessctl -r'

timeout 180 'niri msg power-off-monitors' resume 'niri msg power-on-monitors'
# Lock screen
timeout 300 'qs -p ~/.config/quickshell/Lock.qml'

# Monitor power management
timeout 330 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors && brightnessctl -r'


# System suspend
timeout 1800 'systemctl suspend'

# System event hooks
before-sleep 'playerctl pause; qs -p ~/.config/quickshell/Lock.qml'
after-resume 'niri msg action power-on-monitors'
lock 'qs -p ~/.config/quickshell/Lock.qml'
unlock 'niri msg action power-on-monitors'
